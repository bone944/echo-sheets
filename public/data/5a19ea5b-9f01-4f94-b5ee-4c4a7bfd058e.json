 new Error(\"Link di invito non valido o scaduto. Richiedi un nuovo invito.\");\n}\n\nconst publicData = authPlugin.settings?.publicData ?? {};\nconst production = publicData.environments?.production ?? {};\n\nconst projectUrl =\n  production.customDomain ||\n  production.projectUrl ||\n  publicData.customDomain ||\n  publicData.projectUrl;\n\nconst apiKey =\n  production.apiKey ||\n  publicData.apiKey;\n\nif (!projectUrl || !apiKey) {\n  throw new Error(\"Configurazione Supabase incompleta.\");\n}\n\nconst response = await fetch(`${projectUrl}/auth/v1/user`, {\n  method: \"PUT\",\n  headers: {\n    \"Content-Type\": \"application/json\",\n    \"apikey\": apiKey,\n    \"Authorization\": `Bearer ${session.access_token}`\n  },\n  body: JSON.stringify({\n    password: newPassword\n  })\n});\n\nconst result = await response.json().catch(() => ({}));\n\nif (!response.ok) {\n  throw new Error(\n    result.message ||\n    result.msg ||\n    \"Impostazione password non riuscita.\"\n  );\n}\n\nif (typeof authPlugin.refreshAuthUser === \"function\") {\n  await authPlugin.refreshAuthUser();\n}\n\nreturn result;","next":"17d1d164-759e-4e65-b4dd-babca12a6409","type":"custom-js"},"ea7eee24-3228-4232-8c6e-06a847b561e4":{"id":"ea7eee24-3228-4232-8c6e-06a847b561e4","name":"characters_list","next":"a7506ffb-2338-4adb-81eb-dac5014a1bbc","type":"fetch-collection","collectionId":"ef32f589-7d9c-4492-a940-8141b30ac036"},"f0591a3d-ef51-4bf4-8576-950bfa22b0b4":{"id":"f0591a3d-ef51-4bf4-8576-950bfa22b0b4","type":"trycatch","branches":[{"id":"d0780539-ae46-47c2-bc05-8304aac944d8","value":"try"},{"id":"4fcefa61-d539-4bd8-a466-cd21e60ea42d","value":"catch"}]}},"trigger":"click","version":2,"firstAction":"1c2baced-231c-4f9c-b201-6ce3d6c6b4f5"}]},"content":{"default":{"text":"New text","disabled":false,"leftIcon":{"uid":"5bda401e-2b94-49e7-b676-e82a7a4531e4","isWwObject":true},"rightIcon":{"uid":"f61ab55a-0b1a-49ab-af31-faf8d3d78b59","isWwObject":true},"buttonType":"button","hasLeftIcon":false,"h